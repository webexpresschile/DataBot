# DataBot - Variables de Entorno
# Copiar este archivo como .env y completar los valores

# ===== SUPABASE =====
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-aqui

# ===== MINIMAX API (LLM gratuito con créditos iniciales) =====
MINIMAX_API_KEY=tu-minimax-api-key

# ===== EMBEDDINGS (configurable) =====
# Por defecto usa Ollama local (GRATIS)
EMBEDDING_BASE_URL=http://localhost:11434/v1
EMBEDDING_MODEL=nomic-embed-text
# Para OpenAI de pago: https://api.openai.com/v1
# Para OpenTextEmbeddings: https://embedding-api.ropoly.dev/v1

# ===== N8N =====
N8N_WEBHOOK_URL=https://tu-n8n.railway.app/webhook
N8N_API_KEY=TU_N8N_API_KEY